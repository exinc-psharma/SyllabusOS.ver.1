# SyllabusOS Environment Variables Template
# Copy this file to .env and fill in your actual keys

# ─── API CONFIGURATION ──────────────────────────────────────────
PORT=3000

# Groq Cloud API (Get your key at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# ─── SUPABASE CONFIGURATION ──────────────────────────────────────
# Find these in your Supabase Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Service Role Key (Required for edge functions/admin tasks)
# WARNING: Keep this secret and never expose it on the frontend!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
